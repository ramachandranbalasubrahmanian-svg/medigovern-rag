# Database
DATABASE_URL=postgresql://medigovern:medigovern@localhost:5432/medigovern

# LLM provider: openai | anthropic | local
LLM_PROVIDER=anthropic
# Embeddings provider: sentence-transformers (free/local) | openai | local
EMBEDDINGS_PROVIDER=sentence-transformers

# Anthropic — required for real LLM answers
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI — only needed if EMBEDDINGS_PROVIDER=openai or LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# API
API_HOST=0.0.0.0
API_PORT=8000

# Embeddings dimension — auto-detected from provider (384 for sentence-transformers, 1536 for openai, 8 for local)
# Override only if you switch models manually:
# EMBEDDING_DIMENSION=384
CHUNK_MAX_CHARS=1200

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://*.lovable.app

# Dashboard analytics (Lovable frontend — see lovable/LOVABLE_ANALYTICS_PROMPT.md)
# VITE_GA4_MEASUREMENT_ID=G-FE6TRT5KLL

# Seed knowledge base on startup if empty (true / false)
SEED_ON_STARTUP=true
